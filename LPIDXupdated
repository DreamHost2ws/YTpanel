#!/bin/bash

# COLORS - BLUE THEME
R="\e[1;34m"  # Bright Blue (Primary)
G="\e[1;32m"
Y="\e[1;33m"
B="\e[1;36m"
C="\e[1;36m"
M="\e[1;35m"
W="\e[1;37m"
N="\e[0m"

# LIGHTPLAYS ASCII ART
