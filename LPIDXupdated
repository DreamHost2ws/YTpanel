    echo -e "${R}в•‘${W}      в–Ҳв–Ҳв•—     в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—        ${R}в•‘${N}"
    echo -e "${R}в•‘${W}      в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қ        ${R}в•‘${N}"
    echo -e "${R}в•‘${W}      в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘           ${R}в•‘${N}"
    echo -e "${R}в•‘${W}      в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘           ${R}в•‘${N}"
    echo -e "${R}в•‘${W}      в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘           ${R}в•‘${N}"
    echo -e "${R}в•‘${W}      в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ  в•ҡв•җв•қ   в•ҡв•җв•қ           ${R}в•‘${N}"
    echo -e "${R}в•‘${Y}                 L I G H T P L A Y S                ${R}в•‘${N}"
    echo -e "${R}в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ${N}"
    echo -e "${Y}                   Powered by LightPlays              ${N}\n"
}

print_divider() {
    echo -e "${R}в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ${N}"
}

print_status() {
    local text="$1"
    echo -e "\n${R}в–¶в–¶ ${W}${text}${N}\n"
}

print_header() {
    clear
    print_lightplays_logo
    print_divider
    echo -e "${W}              LIGHTPLAYS MANAGEMENT CONSOLE            ${N}"
    print_divider
    echo
}

print_footer() {
    echo -e "${R}в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ${N}"
    echo -e "${R}в”Ӯ${W}      LightPlays В© 2026 - All Rights Reserved        ${R}в”Ӯ${N}"
    echo -e "${R}в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ${N}\n"
}

# MAIN MENU LOOP
while true; do
    print_header

    echo -e "${Y}                     MAIN OPTIONS${N}\n"

    echo -e "${R}[1]${W} рҹҡҖ GitHub VPS Maker"
    echo -e "${R}[2]${W} рҹ”§ IDX Tool Setup"
    echo -e "${R}[3]${W} вҡЎ IDX VPS Maker"
    echo -e "${R}[4]${W} рҹҢҗ Real VPS (Any + KVM)"
    echo -e "${R}[5]${W} вқҢ Exit\n"

    print_divider
    echo -ne "${R}в–¶в–¶${W} Select Option [1-5]: ${Y}"
    read op
    echo -ne "${N}"

    case $op in

    1)
        clear
        print_lightplays_logo
        print_status "рҹҡҖ GITHUB VPS MAKER"

        RAM=15000
        CPU=4
        DISK_SIZE=100G
        CONTAINER_NAME=lightplays
        IMAGE_NAME=lightplays/debian12
        VMDATA_DIR="$PWD/vmdata"

        mkdir -p "$VMDATA_DIR"

        echo -e "${G}RAM:${W} $RAM MB"
        echo -e "${G}CPU:${W} $CPU cores"
        echo -e "${G}DISK:${W} $DISK_SIZE"
        echo -e "${G}NAME:${W} $CONTAINER_NAME"
        echo -e "${G}IMAGE:${W} $IMAGE_NAME\n"

        docker run -it --rm \
          --name "$CONTAINER_NAME" \
          --device /dev/kvm \
          -v "$VMDATA_DIR":/vmdata \
          -e RAM="$RAM" \
          -e CPU="$CPU" \
          -e DISK_SIZE="$DISK_SIZE" \
          "$IMAGE_NAME"

        read -p "Press Enter to return..."
        ;;

    2)
        clear
        print_lightplays_logo
        print_status "рҹ”§ IDX TOOL SETUP"

        cd
        rm -rf myapp flutter
        mkdir -p vps123/.idx
        cd vps123/.idx

        cat <<EOF > dev.nix
{ pkgs, ... }: {
  channel = "stable-24.05";
  packages = with pkgs; [
    unzip openssh git qemu_kvm sudo cdrkit cloud-utils qemu
  ];
  env = { EDITOR = "nano"; };
}
EOF

        echo -e "${G}IDX setup complete.${N}"
        read -p "Press Enter to return..."
        ;;

    3)
        clear
        print_lightplays_logo
        print_status "вҡЎ IDX VPS MAKER"

        bash <(curl -fsSL https://raw.githubusercontent.com/DreamHost2ws/YTpanel/main/LPIDXupdated)

        read -p "Press Enter to return..."
        ;;

    4)
        clear
        print_lightplays_logo
        print_status "рҹҢҗ REAL VPS (ANY + KVM)"

        bash <(curl -s https://raw.githubusercontent.com/nobita329/The-Coding-Hub/refs/heads/main/srv/vm/dd.sh)
        bash <(curl -fsSL https://raw.githubusercontent.com/DreamHost2ws/YTpanel/main/LPIDXupdated)

        read -p "Press Enter to return..."
        ;;

    5)
        clear
        print_lightplays_logo
        echo -e "${W}             SESSION TERMINATED${N}\n"
        echo -e "${Y}Thank you for using LightPlays!${N}"
        print_footer
        sleep 2
        exit 0
        ;;

    *)
        echo -e "${R}Invalid option. Please choose 1-5.${N}"
        sleep 2
        ;;
    esac

done
