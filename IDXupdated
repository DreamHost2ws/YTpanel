#!/bin/bash

# COLORS - RED THEME
R="\e[1;31m"
G="\e[1;32m"
Y="\e[1;33m"
B="\e[1;34m"
C="\e[1;36m"
M="\e[1;35m"
W="\e[1;37m"
N="\e[0m"

# =========================================================
# LIGHTINGPLAYS ASCII LOGO
# =========================================================
print_logo() {
    echo -e "\n${R}╔══════════════════════════════════════════════════════╗${N}"
    echo -e "${R}║${W}  ██╗     ██╗ ██████╗ ██╗  ██╗████████╗██╗███╗   ██╗  ${R}║${N}"
    echo -e "${R}║${W}  ██║     ██║██╔════╝ ██║  ██║╚══██╔══╝██║████╗  ██║  ${R}║${N}"
    echo -e "${R}║${W}  ██║     ██║██║  ███╗███████║   ██║   ██║██╔██╗ ██║  ${R}║${N}"
    echo -e "${R}║${W}  ██║     ██║██║   ██║██╔══██║   ██║   ██║██║╚██╗██║  ${R}║${N}"
    echo -e "${R}║${W}  ███████╗██║╚██████╔╝██║  ██║   ██║   ██║██║ ╚████║  ${R}║${N}"
    echo -e "${R}║${W}  ╚══════╝╚═╝ ╚═════╝ ╚═╝  ╚═╝   ╚═╝   ╚═╝╚═╝  ╚═══╝  ${R}║${N}"
    echo -e "${R}║${Y}               L I G H T I N G P L A Y S               ${R}║${N}"
    echo -e "${R}╚══════════════════════════════════════════════════════╝${N}"
    echo -e "${Y}                 Made by LightingPlays                  ${N}\n"
}

print_header() {
    clear
    print_logo
    echo -e "${R}══════════════════════════════════════════════════════${N}"
    echo -e "${W}              DEVELOPMENT MANAGEMENT CONSOLE           ${N}"
    echo -e "${R}══════════════════════════════════════════════════════${N}\n"
}

print_option() {
    echo -e "  ${R}╔════════════════════════════════════════════════════╗${N}"
    echo -e "  ${R}║${W}  [$1]  ${Y}$2${R}$(printf '%*s' $((38 - ${#2})))║${N}"
    echo -e "  ${R}╚════════════════════════════════════════════════════╝${N}\n"
}

print_divider() {
    echo -e "${R}══════════════════════════════════════════════════════${N}"
}

print_footer() {
    echo -e "${R}┌────────────────────────────────────────────────────┐${N}"
    echo -e "${R}│${W}     LightingPlays © 2026 - All Rights Reserved     ${R}│${N}"
    echo -e "${R}└────────────────────────────────────────────────────┘${N}\n"
}

# =========================================================
# MAIN LOOP
# =========================================================
while true; do
    print_header

    print_option "1" "🚀 GitHub VPS Maker"
    print_option "2" "🔧 IDX Tool Setup"
    print_option "3" "⚡ IDX VPS Maker"
    print_option "4" "🌐 Real VPS (Any + KVM)"
    print_option "5" "❌ Exit"

    print_divider
    echo -ne "${R}▶▶${W} Select Option [1-5] : ${Y}"
    read op
    echo -ne "${N}"

    case $op in

    1)
        clear
        print_logo
        echo -e "${G}Launching GitHub VPS...${N}"
        sleep 2
        ;;

    2)
        clear
        print_logo
        echo -e "${G}Setting up IDX Tool...${N}"
        sleep 2
        ;;

    3)
        clear
        print_logo
        echo -e "${G}Executing IDX VPS Maker...${N}"
        sleep 2
        ;;

    4)
        clear
        print_logo
        echo -e "${G}Deploying Real VPS Module...${N}"
        sleep 2
        ;;

    5)
        clear
        print_logo
        echo -e "${R}══════════════════════════════════════════════════════${N}"
        echo -e "${W}                 SESSION TERMINATED                   ${N}"
        echo -e "${R}══════════════════════════════════════════════════════${N}\n"
        echo -e "${W}Thank you for using LightingPlays!${N}"
        echo -e "${Y}Made with ❤️ by LightingPlays${N}\n"
        print_footer
        exit 0
        ;;

    *)
        echo -e "${R}Invalid option! Please select 1-5.${N}"
        sleep 2
        ;;
    esac
done
